# HeroRPG — SFTP deploy credentials (TEMPLATE)
# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in the real values there. `.env` is
# gitignored and MUST NEVER be committed. This template (.env.example) IS
# committed and must contain placeholders only — no real secrets.
#
# Used by the deploy script to push the static site to your Strato subdomain
# over SFTP. Load it in a shell with:  set -a && . ./.env && set +a
# ---------------------------------------------------------------------------

# --- Connection -------------------------------------------------------------
# Strato SFTP host. Usually your domain or Strato's SSH host (e.g. ssh.strato.de).
SFTP_HOST=

# SFTP port. Strato SFTP is normally 22.
SFTP_PORT=22

# Strato SFTP / master login username.
SFTP_USER=

# --- Authentication (choose ONE) --------------------------------------------
# Option 1 — password. Simple, but stored in this file; keep .env readable only
# by you (chmod 600). Leave blank if using a key.
SFTP_PASSWORD=

# Option 2 — SSH private key (recommended). Absolute path to your key file.
# If set, this takes precedence over SFTP_PASSWORD. Leave blank if using a password.
SFTP_KEY_PATH=

# --- Destination ------------------------------------------------------------
# The document-root folder the subdomain maps to in your Strato webspace,
# as an absolute path on the server (e.g. /hero or /subdomains/hero).
# This is where index.html should land — the site's files go directly inside it.
SFTP_REMOTE_DIR=

# Public URL of the subdomain, for a post-deploy sanity check (optional).
# e.g. https://hero.yourdomain.tld
DEPLOY_URL=
